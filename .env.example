PORT=3000
NAVER_MAP_CLIENT_ID=your_naver_client_id_here
KAKAO_JS_KEY=your_kakao_javascript_key_here
ADMIN_PASSWORD=admin1234
NODE_ENV=development

# Firebase Admin SDK 서비스 계정 JSON (한 줄 문자열로)
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성 후 아래에 붙여넣기
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}
